---
import { type CollectionEntry } from 'astro:content';
import Image from '#components/Image.astro';

type Props = {
    person: CollectionEntry<'people'>;
    size?: 'lg' | 'sm'
};

const { person, size = 'lg' } = Astro.props;

const typeLabel = {
    member: 'Member',
    former: 'Former',
    external: 'External',
};

const link = person.data.hasPage ? `/people/${person.id}` : person.data.personalURL;
const Element = link !== undefined ? 'a' : 'div';
---
<Element
    class="h-full max-w-[200px] items-start py-4"
    class:list={link !== undefined ? [
        size === 'lg' ? '' : 'btn-sm',
        'btn btn-ghost', 'hover:bg-base-200/07',
    ] : [
        size === 'lg' ? 'px-4' : 'px-3',
    ]}
    {...(link !== undefined ? {
        href: link ?? undefined,
        target: person.data.hasPage ? '_self' : '_blank',
    } : {})}
>
    <article class="flex flex-col gap-2">
        <Image src={person.data.photo} size={250} class="rounded-full shadow-lg" responsive placeholder="mdi:account"/>
        <div class="flex flex-col text-center">
            <h3
                class="font-semibold"
                class:list={size === 'lg' ? 'text-lg' : 'text-xs leading-4'}
            >{person.data.name}</h3>
            <span
                class="font-semibold opacity-70"
                class:list={size === 'lg' ? 'text-sm' : 'text-[0.625rem] leading-4'}
            >{person.data.role}{person.data.type !== 'member' ? ` (${typeLabel[person.data.type]})` : ''}</span>
        </div>
    </article>
</Element>
